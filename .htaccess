Options -Indexes
DirectoryIndex index.html

RewriteEngine On

# Redirect legacy .jsp URLs first (before any other rules)
RewriteRule ^index\.jsp$    / [R=301,L]
RewriteRule ^about\.jsp$    /about.html [R=301,L]
RewriteRule ^services\.jsp$ /services.html [R=301,L]
RewriteRule ^faq\.jsp$      /faq.html [R=301,L]
RewriteRule ^contact\.jsp$  /contact.html [R=301,L]

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Force www
RewriteCond %{HTTP_HOST} ^specialized-med\.com [NC]
RewriteRule ^(.*)$ https://www.specialized-med.com/$1 [L,R=301]

ErrorDocument 404 /404.html